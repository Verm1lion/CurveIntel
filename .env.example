# Copy this file to `.env` before running CurveIntel.
# Local development with uvicorn expects `alembic upgrade head` to be run first.

# Database settings
# For local development (uvicorn), SQLite works out of the box:
DATABASE_URL=sqlite:///./curveintel.db
# For Docker Compose, the compose file sets DATABASE_URL automatically.
# If you need to override it manually:
# DATABASE_URL=postgresql+psycopg2://curveintel:curveintel@postgres:5432/curveintel
DB_ECHO=false
DB_POOL_PRE_PING=true

# Docker/PostgreSQL defaults (used by the postgres service in docker-compose.yml)
POSTGRES_DB=curveintel
POSTGRES_USER=curveintel
POSTGRES_PASSWORD=curveintel

# Auth / RBAC
CURVEINTEL_ENV=development
JWT_SECRET_KEY=change-this-in-real-environments
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_TOKEN_COOKIE_NAME=curveintel_access_token
AUTH_COOKIE_SECURE=false
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@curveintel.local
AUTH_BOOTSTRAP_ADMIN_FULL_NAME=CurveIntel Admin
# Leave blank to use the bootstrap form on /login for the first admin.
AUTH_BOOTSTRAP_ADMIN_PASSWORD=

# API / Browser access
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID
CORS_ALLOW_CREDENTIALS=true

# Optional explicit demo seed
CURVEINTEL_LOAD_DEMO_DATA=false
CURVEINTEL_DEMO_DATA_DIR=
